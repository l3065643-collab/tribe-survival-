local function createToggle(text, defaultState, callback)
    local state = defaultState
    
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(1, 0, 0, 38)
    Frame.BackgroundColor3 = Color3.fromRGB(28, 28, 35)
    Frame.BorderSizePixel = 0
    Frame.Parent = Content

    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 6)
    Corner.Parent = Frame

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.7, 0, 1, 0)
    Label.Position = UDim2.new(0, 12, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = cfg.textColor
    Label.TextSize = 13
    Label.Font = Enum.Font.SourceSansBold
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Frame

    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(0, 50, 0, 22)
    Button.Position = UDim2.new(1, -62, 0.5, -11)
    Button.BackgroundColor3 = state and currentChromaColor or Color3.fromRGB(45, 45, 50)
    Button.Text = state and "ВКЛ" or "ВЫКЛ"
    Button.TextColor3 = Color3.fromRGB(15, 15, 20)
    Button.TextSize = 11
    Button.Font = Enum.Font.SourceSansBold
    Button.Parent = Frame

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 11)
    BtnCorner.Parent = Button

    Button.MouseButton1Click:Connect(function()
        state = not state
        Button.BackgroundColor3 = state and currentChromaColor or Color3.fromRGB(45, 45, 50)
        Button.Text = state and "ВКЛ" or "ВЫКЛ"
        callback(state)
    end)

    -- Синхронизация активных кнопок со стилем Chroma RGB
    RunService.RenderStepped:Connect(function()
        if state then 
            Button.BackgroundColor3 = currentChromaColor 
        end
    end)
end

