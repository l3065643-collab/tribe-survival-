local function startAutoHitLoop()
    task.spawn(function()
        while true do
            if not _G.vaennarAutoHit then 
                task.wait(0.2)
            else
                local char = lp.Character
                if char then
                    local tool = char:FindFirstChildOfClass("Tool")
                    if tool then
                        -- Локальная активация инструмента
                        pcall(function() tool:Activate() end)
                        
                        -- Триггер удара через удаленные события
                        pcall(function()
                            for _, child in ipairs(tool:GetDescendants()) do
                                if child:IsA("RemoteEvent") then 
                                    child:FireServer()
                                elseif child:IsA("BindableEvent") then 
                                    child:Fire() 
                                end
                            end
                        end)
                    end
                end
                task.wait(0.04) -- Высокая скорость ударов (25 кликов в секунду)
            end
        end
    end)
end

